#include <iostream>
#include <vector>
using namespace std;
 
int main() {
    int n;
    cin >> n;
    vector<int> a(n);
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }
 
   
    int evenCount = 0, oddCount = 0;
    for (int i = 0; i < 3; ++i) {
        if (a[i] % 2 == 0) evenCount++;
        else oddCount++;
    }
 
    bool lookingForEven = (oddCount > evenCount); 
    bool lookingForOdd = (evenCount > oddCount);  
 
    for (int i = 0; i < n; ++i) {
        if (lookingForEven && a[i] % 2 == 0) {
            cout << i + 1 << endl;
            break;
        }
        if (lookingForOdd && a[i] % 2 == 1) {
            cout << i + 1 << endl;
            break;
        }
    }
 
    return 0;
}
